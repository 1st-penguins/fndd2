rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // 🛡️ 보안 함수 정의 (Security Functions)
    // ============================================
    
    // 관리자 여부 확인 (이메일 목록 + DB 기반)
    function isAdmin() {
      let adminEmails = ['kspo0324@gmail.com', 'mingdy7283@gmail.com', 'sungsoo702@gmail.com', 'pyogobear@gmail.com'];
      return request.auth != null && (
        request.auth.token.email in adminEmails || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
      );
    }

    // 본인 확인 함수
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // 로그인 여부 확인
    function isLoggedIn() {
      return request.auth != null;
    }

    // 공지 조회수 증가 전용 업데이트 허용 (비관리자)
    function canIncrementNoticeView() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['viewCount', 'lastViewedAt']);
    }

    // 공지 좋아요 업데이트 허용 (로그인 사용자)
    function canUpdateNoticeLikes() {
      return isLoggedIn() &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes']);
    }

    // visits 문서 유효성 검사 (공지 방문 집계용)
    function isValidVisitPayload() {
      return request.resource.data.keys().hasOnly(['page', 'dateKey', 'visitorId', 'userId', 'isLoggedIn', 'visitedAt']) &&
             request.resource.data.page is string &&
             request.resource.data.page == 'notices' &&
             request.resource.data.dateKey is string &&
             request.resource.data.dateKey.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             request.resource.data.visitorId is string &&
             request.resource.data.visitorId.size() >= 8 &&
             request.resource.data.visitorId.size() <= 80 &&
             request.resource.data.isLoggedIn is bool &&
             request.resource.data.visitedAt is timestamp &&
             (request.resource.data.userId == null || request.resource.data.userId is string) &&
             (
               (request.auth == null && request.resource.data.userId == null && request.resource.data.isLoggedIn == false) ||
               (request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.isLoggedIn == true)
             );
    }

    function canWriteVisit(visitId) {
      return isValidVisitPayload() &&
             visitId == request.resource.data.page + "_" + request.resource.data.dateKey + "_" + request.resource.data.visitorId;
    }

    // ============================================
    // 👤 사용자 데이터 (Users)
    // ============================================
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // 하위 컬렉션 포함 모든 데이터
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // ============================================
    // 📚 강좌 및 상품 (Products & Lectures) - ⚠️ 중요 보안
    // ============================================
    // 상품 정보 — 비로그인도 상점 탐색 가능
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 에피소드 (커리큘럼) — 비로그인도 목록 확인 가능
    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 강의 진도율
    match /lectureProgress/{progressId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // PDF 다운로드 기록
    match /pdfDownloads/{downloadId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 쿠폰
    match /coupons/{couponId} {
      allow read: if isLoggedIn();
      // 일반 사용자: usedCount 증가만 허용
      allow update: if isLoggedIn() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['usedCount']) &&
        request.resource.data.usedCount == resource.data.usedCount + 1;
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // 쿠폰 사용 내역
    match /couponUsage/{usageId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // 강의 콘텐츠 (레거시)
    match /lectures/{lectureId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ============================================
    // 📦 구매 및 권한 (Purchases) (Pro Feature)
    // ============================================
    match /purchases/{purchaseId} {
      // 본인의 구매 내역만 읽기/생성 가능 (resource == null: 구매 여부 확인 시 문서 미존재 허용)
      allow read: if isLoggedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin(); // 사용자는 구매 내역 수정 불가
    }

    // ============================================
    // 📝 학습 데이터 (Attempts, Mock Exams)
    // ============================================
    
    // 통합된 문제 풀이 기록
    match /attempts/{attemptId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (isLoggedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }
    
    // 모의고사 결과
    match /mockExamResults/{resultId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (isLoggedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }
    
    // 사용자 진행률 (User Progress)
    match /userProgress/{userId} {
      allow read, write: if isLoggedIn() && (isOwner(userId) || isAdmin());
    }
    
    // 사용자 통계 (User Statistics)
    match /userStatistics/{userId} {
      allow read, write: if isLoggedIn() && (isOwner(userId) || isAdmin());
    }
    
    // 퀴즈/모의고사 세션 (중복 규칙 통합)
    match /quizSessions/{sessionId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (isLoggedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }
    match /sessions/{sessionId} {
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if (isLoggedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ============================================
    // 📝 오답 노트 (Wrong Answers)
    // ============================================
    match /wrong_answers/{docId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // 🔖 북마크 (Bookmarks)
    // ============================================
    match /bookmarks/{docId} {
      allow read: if isLoggedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // 📢 커뮤니티 (Notices, Comments, Likes)
    // ============================================
    match /notices/{noticeId} {
      allow read: if true; // 공개
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || canIncrementNoticeView() || canUpdateNoticeLikes();
    }

    match /visits/{visitId} {
      allow create: if canWriteVisit(visitId);
      allow update: if canWriteVisit(visitId) &&
                    request.resource.data.page == resource.data.page &&
                    request.resource.data.dateKey == resource.data.dateKey &&
                    request.resource.data.visitorId == resource.data.visitorId;
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if (isLoggedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ============================================
    // 💬 1:1 문의 (Inquiries)
    // ============================================
    match /inquiries/{inquiryId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ============================================
    // ⚙️ 시스템 및 통계 (System & Stats)
    // ============================================
    // 문제는 누구나 읽기 가능 (클라이언트에서 문제 풀이를 위해 필요)
    match /exams/{matchId} { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /mockexams/{matchId} { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /mockExams/{matchId} { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /mockExams/{matchId}/{document=**} { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    
    match /questionSets/{setId} { allow read: if isLoggedIn(); allow write: if isAdmin(); }
    match /questionStats/{questionId} { allow read: if isLoggedIn(); allow write: if isAdmin(); }

    match /adminStats/{statId} {
      allow read, write: if isAdmin();
    }

    // 자격증별 일일 이용자 집계
    match /certDailyUsers/{dateKey} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Function에서만 기록
    }

    // 오늘의 방문자 집계 (daily_visits/{YYYY-MM-DD})
    match /daily_visits/{dateKey} {
      // 로그인한 사용자는 본인 uid 키만 추가/수정 가능
      allow create: if isLoggedIn() &&
                    request.resource.data.users.keys().hasOnly([request.auth.uid]);
      allow update: if isLoggedIn() &&
                    request.resource.data.users.diff(resource.data.users).changedKeys().hasOnly([request.auth.uid]);
      // 읽기는 관리자만
      allow read: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================
    // 🚫 기본 차단 (Default Deny)
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
