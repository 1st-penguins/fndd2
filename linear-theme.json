{
  "name": "Linear Design System",
  "version": "1.0.0",
  "description": "Linear.app에서 추출한 디자인 시스템 테마",
  "theme": {
    "colors": {
      "primary": {
        "brand": "#5e6ad2",
        "accent": "#7170ff",
        "accentHover": "#828fff",
        "indigo": "#5e6ad2"
      },
      "background": {
        "primary": "#08090a",
        "secondary": "#1c1c1f",
        "tertiary": "#232326",
        "level0": "#08090a",
        "level1": "#0f1011",
        "level2": "#141516",
        "level3": "#191a1b",
        "marketing": "#010102",
        "translucent": "rgba(255,255,255,.05)",
        "tint": "#141516"
      },
      "text": {
        "primary": "#f7f8f8",
        "secondary": "#d0d6e0",
        "tertiary": "#8a8f98",
        "quaternary": "#62666d",
        "brand": "#fff"
      },
      "border": {
        "primary": "#23252a",
        "secondary": "#34343a",
        "tertiary": "#3e3e44",
        "translucent": "rgba(255,255,255,.05)"
      },
      "line": {
        "primary": "#37393a",
        "secondary": "#202122",
        "tertiary": "#18191a",
        "quaternary": "#141515",
        "tint": "#141516"
      },
      "accent": {
        "alpha": "255",
        "tint": "#18182f"
      },
      "semantic": {
        "red": "#eb5757",
        "green": "#4cb782",
        "blue": "#4ea7fc",
        "orange": "#fc7840",
        "yellow": "#f2c94c"
      },
      "linear": {
        "plan": "#68cc58",
        "build": "#d4b144",
        "security": "#7a7fad"
      },
      "selection": {
        "bg": "color-mix(in lch,#5e6ad2,black 10%)",
        "text": "#fff",
        "dim": "color-mix(in lch,#5e6ad2,transparent 80%)"
      },
      "link": {
        "primary": "#828fff",
        "hover": "#fff"
      }
    },
    "typography": {
      "fontFamily": {
        "primary": "\"Inter Variable\",\"SF Pro Display\",-apple-system,BlinkMacSystemFont,\"Segoe UI\",\"Roboto\",\"Oxygen\",\"Ubuntu\",\"Cantarell\",\"Open Sans\",\"Helvetica Neue\",sans-serif",
        "serif": "\"Tiempos Headline\",ui-serif,Georgia,Cambria,\"Times New Roman\",Times,serif",
        "monospace": "\"Berkeley Mono\",ui-monospace,\"SF Mono\",\"Menlo\",monospace",
        "emoji": "\"Apple Color Emoji\",\"Segoe UI Emoji\",\"Segoe UI Symbol\",\"Segoe UI\",\"Twemoji Mozilla\",\"Noto Color Emoji\",\"Android Emoji\""
      },
      "fontWeight": {
        "light": 300,
        "normal": 400,
        "medium": 510,
        "semibold": 590,
        "bold": 680
      },
      "fontSize": {
        "tiny": "0.625rem",
        "micro": "0.6875rem",
        "mini": "0.75rem",
        "small": "0.8125rem",
        "regular": "0.9375rem",
        "large": "1.0625rem",
        "title1": "1.0625rem",
        "title2": "1.5rem",
        "title3": "1.25rem",
        "title4": "2rem",
        "title5": "2.5rem",
        "title6": "3rem",
        "title7": "3.5rem",
        "title8": "4rem",
        "title9": "4.5rem"
      },
      "lineHeight": {
        "tiny": 1.5,
        "micro": 1.4,
        "mini": 1.5,
        "small": 1.5,
        "regular": 1.6,
        "large": 1.6,
        "title1": 1.4,
        "title2": 1.33,
        "title3": 1.33,
        "title4": 1.125,
        "title5": 1.1,
        "title6": 1.1,
        "title7": 1.1,
        "title8": 1.06,
        "title9": 1
      },
      "letterSpacing": {
        "tiny": "-0.015em",
        "mini": "-0.01em",
        "small": "-0.013em",
        "regular": "-0.011em",
        "large": "0",
        "title1": "-0.012em",
        "title2": "-0.012em",
        "title3": "-0.012em",
        "title4": "-0.022em",
        "title5": "-0.022em",
        "title6": "-0.022em",
        "title7": "-0.022em",
        "title8": "-0.022em",
        "title9": "-0.022em"
      }
    },
    "spacing": {
      "pagePadding": {
        "inline": "24px",
        "block": "64px",
        "left": "max(0px,24px)",
        "right": "max(0px,24px)"
      },
      "header": {
        "height": "64px",
        "blur": "20px",
        "border": "rgba(255,255,255,.08)"
      },
      "radius": {
        "4": "4px",
        "6": "6px",
        "8": "8px",
        "12": "12px",
        "16": "16px",
        "24": "24px",
        "32": "32px",
        "rounded": "9999px",
        "circle": "50%"
      }
    },
    "layout": {
      "maxWidth": {
        "page": "1024px",
        "prose": "624px"
      },
      "grid": {
        "columns": 12
      },
      "viewport": {
        "svh": "1svh",
        "dvh": "1dvh",
        "100svh": "calc(100*1svh)",
        "100dvh": "calc(100*1dvh)"
      }
    },
    "shadows": {
      "none": "0px 0px 0px transparent",
      "tiny": "0px 0px 0px transparent",
      "low": "0px 2px 4px rgba(0,0,0,.1)",
      "medium": "0px 4px 24px rgba(0,0,0,.2)",
      "high": "0px 7px 32px rgba(0,0,0,.35)",
      "stackLow": "0px 8px 2px 0px transparent,0px 5px 2px 0px rgba(0,0,0,.01),0px 3px 2px 0px rgba(0,0,0,.04),0px 1px 1px 0px rgba(0,0,0,.07),0px 0px 1px 0px rgba(0,0,0,.08)"
    },
    "animations": {
      "easing": {
        "easeInQuad": "cubic-bezier(.55,.085,.68,.53)",
        "easeOutQuad": "cubic-bezier(.25,.46,.45,.94)",
        "easeInOutQuad": "cubic-bezier(.455,.03,.515,.955)",
        "easeInCubic": "cubic-bezier(.55,.055,.675,.19)",
        "easeOutCubic": "cubic-bezier(.215,.61,.355,1)",
        "easeInOutCubic": "cubic-bezier(.645,.045,.355,1)",
        "easeInQuart": "cubic-bezier(.895,.03,.685,.22)",
        "easeOutQuart": "cubic-bezier(.165,.84,.44,1)",
        "easeInOutQuart": "cubic-bezier(.77,0,.175,1)",
        "easeInQuint": "cubic-bezier(.755,.05,.855,.06)",
        "easeOutQuint": "cubic-bezier(.23,1,.32,1)",
        "easeInOutQuint": "cubic-bezier(.86,0,.07,1)",
        "easeInCirc": "cubic-bezier(.6,.04,.98,.335)",
        "easeOutCirc": "cubic-bezier(.075,.82,.165,1)",
        "easeInOutCirc": "cubic-bezier(.785,.135,.15,.86)",
        "easeInExpo": "cubic-bezier(.95,.05,.795,.035)",
        "easeOutExpo": "cubic-bezier(.19,1,.22,1)",
        "easeInOutExpo": "cubic-bezier(1,0,0,1)"
      },
      "duration": {
        "quickTransition": "0.1s",
        "regularTransition": "0.25s",
        "highlightFadeIn": "0s",
        "highlightFadeOut": "0.15s"
      }
    },
    "layers": {
      "footer": 50,
      "header": 100,
      "layer1": 1,
      "layer2": 2,
      "layer3": 3,
      "overlay": 500,
      "skipNav": 5000,
      "popover": 600,
      "dialog": 700,
      "dialogOverlay": 699,
      "toasts": 800,
      "commandMenu": 650,
      "tooltip": 1100,
      "contextMenu": 1200,
      "debug": 5100,
      "max": 10000
    },
    "focus": {
      "ring": {
        "width": "2px",
        "offset": "2px",
        "color": "#5e6ad2",
        "outline": "2px solid #5e6ad2"
      }
    },
    "interactive": {
      "minTapSize": "44px",
      "cursor": {
        "pointer": "pointer",
        "disabled": "not-allowed",
        "tooltip": "help",
        "none": "none"
      }
    },
    "scrollbar": {
      "size": "6px",
      "sizeActive": "10px",
      "gap": "4px",
      "color": "rgba(255,255,255,.1)",
      "colorHover": "rgba(255,255,255,.2)",
      "colorActive": "rgba(255,255,255,.4)"
    },
    "mask": {
      "visible": "black",
      "off": "transparent",
      "on": "black",
      "invisible": "transparent",
      "ease": "rgba(0,0,0,.2)"
    },
    "overlay": {
      "primary": "rgba(0,0,0,.9)",
      "dimRgb": "255,255,255"
    }
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#5e6ad2",
        "color": "#fff",
        "borderRadius": "8px",
        "padding": "0px 16px",
        "fontSize": "15px",
        "fontWeight": 510,
        "border": "1px solid #5e6ad2"
      },
      "secondary": {
        "backgroundColor": "#28282c",
        "color": "#f7f8f8",
        "borderRadius": "10px",
        "padding": "0px 16px",
        "fontSize": "15px",
        "fontWeight": 510,
        "border": "1px solid #3e3e44"
      },
      "ghost": {
        "backgroundColor": "transparent",
        "color": "#8a8f98",
        "borderRadius": "8px",
        "padding": "0px 12px",
        "fontSize": "13px",
        "fontWeight": 510,
        "border": "none"
      }
    },
    "card": {
      "feature": {
        "backgroundColor": "#0f1011",
        "color": "#f7f8f8",
        "borderRadius": "16px",
        "padding": "32px 24px",
        "border": "none",
        "display": "flex",
        "textDecoration": "none"
      }
    },
    "navigation": {
      "header": {
        "backgroundColor": "rgba(11,11,11,.8)",
        "height": "64px",
        "color": "#f7f8f8",
        "fontSize": "16px",
        "backdropFilter": "blur(20px)"
      }
    }
  }
}

